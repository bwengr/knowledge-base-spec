{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://github.com/bwengr/knowledge-base-spec/schema.json",
  "title": "Knowledge Base JSON",
  "description": "Schema for structured JSON knowledge bases that ground AI responses in real content",
  "type": "object",
  "required": ["name", "description", "sections"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the website or knowledge base"
    },
    "description": {
      "type": "string",
      "description": "Brief description of what this knowledge base covers"
    },
    "baseUrl": {
      "type": "string",
      "format": "uri",
      "description": "Base URL of the website"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the knowledge base was generated"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/section"
      }
    }
  },
  "definitions": {
    "section": {
      "type": "object",
      "required": ["id", "url", "type", "title", "chunks"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this section within the knowledge base"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Full URL to the source page"
        },
        "type": {
          "type": "string",
          "enum": ["blog-post", "service-page", "portfolio", "faq", "general"],
          "description": "Content type of this section"
        },
        "title": {
          "type": "string",
          "description": "Title of the page or section"
        },
        "meta": {
          "type": "object",
          "properties": {
            "author": { "type": "string" },
            "pubDate": { "type": "string", "format": "date" },
            "tags": {
              "type": "array",
              "items": { "type": "string" }
            },
            "description": { "type": "string" }
          }
        },
        "chunks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/chunk"
          }
        }
      }
    },
    "chunk": {
      "type": "object",
      "required": ["content", "position"],
      "properties": {
        "content": {
          "type": "string",
          "minLength": 10,
          "description": "Text content of this chunk, typically 1-3 paragraphs"
        },
        "position": {
          "type": "integer",
          "minimum": 1,
          "description": "Order of this chunk within the parent section"
        }
      }
    }
  }
}